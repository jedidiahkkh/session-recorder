#!/usr/bin/env bash
set -euo pipefail

# Find the real claude binary — picks the most recently modified version
# so this keeps working after claude auto-updates
VERSIONS_DIR="$HOME/.local/share/claude/versions"
REAL_CLAUDE="$VERSIONS_DIR/$(ls -t "$VERSIONS_DIR" | head -1)"

if [[ ! -x "$REAL_CLAUDE" ]]; then
    echo "Error: could not find a runnable claude binary in $VERSIONS_DIR" >&2
    exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")" && pwd)"
exec "$SCRIPT_DIR/record-session" "$REAL_CLAUDE" "$@"
